{
    "$schema": "https://mintlify.com/docs.json",
    "theme": "mint",
    "name": "Nubo Docs",
    "colors": {
        "primary": "#8085ff",
        "light": "#8085ff",
        "dark": "#8085ff"
    },
    "background": {
        "color": {
            "dark": "#0a0a0a",
            "light": "#0a0a0a"
        }
    },
    "favicon": "/logo/favicon.png",
    "navigation": {
        "tabs": [
            {
                "tab": "Documentation",
                "groups": [
                    {
                        "group": "Get started",
                        "pages": [
                            "index",
                            "quickstart",
                            "concepts-and-terms"
                        ]
                    },
                    {
                        "group": "Deploy guides",
                        "pages": [
                            "deploy-guides/golang",
                            {
                                "group": "Node.js",
                                "icon": "node-js",
                                "pages": [
                                    "deploy-guides/nodejs",
                                    "deploy-guides/javascript/react",
                                    "deploy-guides/javascript/discordjs"
                                ]
                            },
                            "deploy-guides/python",
                            "deploy-guides/php",
                            "deploy-guides/static",
                            "deploy-guides/rust"
                        ]
                    },
                    {
                        "group": "Core concepts",
                        "pages": [
                            "frames",
                            "deployments",
                            "ci-cd",
                            "preview-deployments",
                            "build-logs",
                            "rollback",
                            "environment-variables",
                            "custom-domains",
                            "volumes"
                        ]
                    },
                    {
                        "group": "Account",
                        "pages": [
                            "plans"
                        ]
                    },
                    {
                        "group": "Self-hosted agents",
                        "pages": [
                            "agents/overview",
                            "agents/quickstart",
                            "agents/advanced"
                        ]
                    },
                    {
                        "group": "API reference",
                        "pages": [
                            "api-reference/authentication",
                            "api-reference/rate-limits",
                            "api-reference/error-codes",
                            "api-reference/stability"
                        ]
                    }
                ]
            },
            {
                "tab": "Raypacks",
                "groups": [
                    {
                        "group": "About",
                        "pages": [
                            "raypacks/overview"
                        ]
                    },
                    {
                        "group": "Packs",
                        "pages": [
                            "raypacks/packs/go",
                            "raypacks/packs/node",
                            "raypacks/packs/static",
                            "raypacks/packs/dockerfile"
                        ]
                    },
                    {
                        "group": "Configuration",
                        "pages": [
                            "raypacks/nubo-toml",
                            "raypacks/build-cache"
                        ]
                    },
                    {
                        "group": "Reference",
                        "pages": [
                            "raypacks/cli"
                        ]
                    }
                ]
            },
            {
                "tab": "Release notes",
                "pages": [
                    "release-notes"
                ]
            }
        ]
    },
    "logo": {
        "light": "/logo/logo.png",
        "dark": "/logo/logo.png"
    },
    "navbar": {
        "links": [
            {
                "label": "Support",
                "href": "mailto:support@withnubo.com"
            }
        ],
        "primary": {
            "type": "button",
            "label": "Sign in",
            "href": "https://console.withnubo.com/login"
        }
    },
    "contextual": {
        "options": [
            "copy",
            "view",
            "chatgpt",
            "claude",
            "perplexity",
            "mcp",
            "cursor",
            "vscode"
        ]
    },
    "footer": {
        "socials": {
            "x": "https://x.com/mintlify",
            "github": "https://github.com/mintlify",
            "linkedin": "https://linkedin.com/company/mintlify"
        }
    }
}
